// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCabello {
  liso
  ondulado
  rizado
}

enum TipoDomicilio {
  casa
  trabajo
}

enum EstadoPedido {
  borrador
  pendiente_pago
  pagado
  preparando
  enviado
  entregado
  cancelado
}

enum EstadoEnvio {
  preparando
  en_transito
  entregado
  fallido
}

enum EstadoPago {
  pendiente
  aprobado
  rechazado
  cancelado
  reembolsado
}

enum MovimientoInventarioTipo {
  entrada
  salida
  ajuste
}

// Tipo mostrado en UI (credito / debito), segun pasarela o BIN.
enum TipoTarjetaGuardada {
  credito
  debito
}

model Usuario {
  id                    String         @id @default(uuid())
  nombre                String
  email                 String         @unique
  telefono              String?
  password              String?
  fechaNacimiento       DateTime?
  googleId              String?        @unique
  foto                  String?
  aceptaAvisoPrivacidad Boolean        @default(false)
  recibePromociones     Boolean        @default(false)
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  codigoOTP             String?
  otpExpira             DateTime?
  confirmado            Boolean        @default(false)
  creadoEn              DateTime       @default(now()) @map("creado_en")
  actualizadoEn         DateTime       @updatedAt @map("actualizado_en")
  activo                Boolean        @default(true)
  
  // Campos de seguridad
  intentosLoginFallidos Int            @default(0) @map("intentos_login_fallidos")
  cuentaBloqueadaHasta  DateTime?      @map("cuenta_bloqueada_hasta")
  ultimoIntentoLogin    DateTime?      @map("ultimo_intento_login")
  ultimaActividad       DateTime?      @map("ultima_actividad") // Última actividad del usuario (para expiración por inactividad)
  tokensRevocadosDesde  DateTime?      @map("tokens_revocados_desde") // Fecha desde la cual todos los tokens anteriores están revocados (para logout global)
  rol                   String         @default("cliente") // admin | estilista | empleado | becario | cliente

  // Campos de perfil capilar (embebidos)
  tipoCabello           TipoCabello?
  colorNatural          String?        @map("color_natural")
  colorActual           String?        @map("color_actual")
  productosUsados       String?        @map("productos_usados")
  alergias              String?

  // Campos de pregunta de seguridad (embebidos)
  preguntaSeguridad     String?        @map("pregunta_seguridad")
  respuestaSeguridad    String?        @map("respuesta_seguridad") // Hasheada con bcrypt

  serviciosComoEspecialista ServicioEspecialista[]
  direcciones                  DireccionUsuario[]
  pedidos                      Pedido[]
  carritoItems                 CarritoItem[]
  valoraciones                 Valoracion[]
  notificaciones               Notificacion[]
  historialCambiosEstadoPedido HistorialEstadoPedido[]
  // Metodos tokenizados guardados (perfil + checkout). No guardar PAN completo ni CVV.
  metodosPagoGuardados       MetodoPagoUsuario[]
  movimientosInventario      InventarioMovimiento[]

  @@index([activo])
  @@index([email])
  @@map("usuarios")
}

// Tarjetas guardadas por usuario (tipo Mercado Libre). Guardar id del proveedor, no el PAN.
model MetodoPagoUsuario {
  id                String               @id @default(uuid())
  proveedor         String // mercadopago, stripe, conekta
  // ID del metodo/tarjeta en la pasarela (tokenizacion).
  idExterno         String               @map("id_externo")
  marca             String?              @map("marca") // visa, mastercard, amex…
  ultimos4          String               @map("ultimos_4") @db.VarChar(4)
  bancoNombre       String?              @map("banco_nombre")
  expMes            Int?                 @map("exp_mes") // 1–12
  expAnio           Int?                 @map("exp_anio") // ej. 2029
  tipoTarjeta       TipoTarjetaGuardada? @map("tipo_tarjeta")
  esVirtual         Boolean              @default(false) @map("es_virtual")
  // Texto opcional para UI (alias).
  etiqueta          String?              @map("etiqueta")
  esPredeterminada  Boolean              @default(false) @map("es_predeterminada")
  activo            Boolean              @default(true) @map("activo")

  creadoEn          DateTime             @default(now()) @map("creado_en")
  actualizadoEn     DateTime             @updatedAt @map("actualizado_en")

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String  @map("usuario_id")

  @@unique([usuarioId, proveedor, idExterno])
  @@index([usuarioId])
  @@index([usuarioId, activo])
  @@map("metodos_pago_usuario")
}

// Direcciones de envío del usuario
model DireccionUsuario {
  id                     String        @id @default(uuid())
  calle                  String        @db.Text
  codigoPostal           String        @map("codigo_postal")
  estado                 String
  municipioAlcaldia      String        @map("municipio_alcaldia")
  localidad              String
  coloniaBarrio          String        @map("colonia_barrio")
  numeroInterior         String?       @map("numero_interior")
  indicaciones           String?       @db.Text
  tipoDomicilio          TipoDomicilio @map("tipo_domicilio")
  contactoNombreApellido String        @map("contacto_nombre_apellido")
  contactoTelefono       String        @map("contacto_telefono")
  esPrincipal            Boolean       @default(false) @map("es_principal")
  creadoEn               DateTime      @default(now()) @map("creado_en")
  actualizadoEn          DateTime      @updatedAt @map("actualizado_en")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String   @map("usuario_id")
  pedidos   Pedido[]

  @@map("direcciones_usuario")
  @@index([usuarioId])
}

model Pedido {
  id                       Int           @id @default(autoincrement())
  estado                   EstadoPedido  @default(borrador)
  subtotal                 Decimal       @db.Decimal(10, 2)
  costoEnvio               Decimal       @default(0) @map("costo_envio") @db.Decimal(10, 2)
  impuestos                Decimal       @default(0) @db.Decimal(10, 2)
  descuento                Decimal       @default(0) @db.Decimal(10, 2)
  total                    Decimal       @db.Decimal(10, 2)
  moneda                   String        @default("MXN")
  direccionTextoCompleta   String?       @map("direccion_texto_completa") @db.Text
  notasCliente             String?       @map("notas_cliente") @db.Text
  metodoPago               String?       @map("metodo_pago")
  referenciaPago           String?       @map("referencia_pago")
  pagadoEn                 DateTime?     @map("pagado_en")
  creadoEn                 DateTime      @default(now()) @map("creado_en")
  actualizadoEn            DateTime      @updatedAt @map("actualizado_en")

  usuario          Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  usuarioId        String            @map("usuario_id")
  direccionEnvio   DireccionUsuario? @relation(fields: [direccionEnvioId], references: [id], onDelete: SetNull)
  direccionEnvioId String?           @map("direccion_envio_id")

  items           PedidoItem[]
  pagos           Pago[]
  envios          Envio[]
  facturas        Factura[]
  valoraciones    Valoracion[]
  devoluciones    Devolucion[]
  historialEstado HistorialEstadoPedido[]

  @@index([usuarioId])
  @@index([estado])
  @@index([creadoEn])
  @@map("pedidos")
}

model PedidoItem {
  id              Int      @id @default(autoincrement())
  cantidad        Int
  precioUnitario  Decimal  @map("precio_unitario") @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  nombreProducto  String?  @map("nombre_producto")
  tamanio         String?

  pedido         Pedido               @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId       Int                  @map("pedido_id")
  producto       Producto             @relation(fields: [productoId], references: [id], onDelete: Restrict)
  productoId     Int                  @map("producto_id")
  presentacion   ProductoPresentacion @relation(fields: [presentacionId], references: [id], onDelete: Restrict)
  presentacionId Int                  @map("presentacion_id")

  devoluciones Devolucion[]

  @@index([pedidoId])
  @@index([pedidoId, productoId])
  @@index([productoId])
  @@map("pedido_items")
}

model CarritoItem {
  id               Int      @id @default(autoincrement())
  cantidad         Int
  precioReferencia Decimal? @map("precio_referencia") @db.Decimal(10, 2)
  activo           Boolean  @default(true)
  creadoEn         DateTime @default(now()) @map("creado_en")
  actualizadoEn    DateTime @updatedAt @map("actualizado_en")

  usuario        Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      String               @map("usuario_id")
  producto       Producto             @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId     Int                  @map("producto_id")
  presentacion   ProductoPresentacion @relation(fields: [presentacionId], references: [id], onDelete: Cascade)
  presentacionId Int                  @map("presentacion_id")

  @@unique([usuarioId, presentacionId])
  @@index([usuarioId])
  @@map("carrito_items")
}

model Pago {
  id                 Int        @id @default(autoincrement())
  intentoNumero      Int        @map("intento_numero")
  monto              Decimal    @db.Decimal(10, 2)
  moneda             String     @default("MXN")
  metodo             String
  proveedor          String?
  estado             EstadoPago @default(pendiente)
  referenciaExterna  String?    @map("referencia_externa")
  errorMensaje       String?    @map("error_mensaje") @db.Text
  payload            Json?
  pagadoEn           DateTime?  @map("pagado_en")
  creadoEn           DateTime   @default(now()) @map("creado_en")
  actualizadoEn      DateTime   @updatedAt @map("actualizado_en")

  pedido    Pedido       @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId  Int          @map("pedido_id")
  devoluciones Devolucion[]

  @@index([pedidoId])
  @@index([estado])
  @@index([referenciaExterna])
  @@map("pagos")
}

model HistorialEstadoPedido {
  id             Int            @id @default(autoincrement())
  estadoAnterior EstadoPedido?  @map("estado_anterior")
  estadoNuevo    EstadoPedido   @map("estado_nuevo")
  origen         String?
  creadoEn       DateTime       @default(now()) @map("creado_en")

  pedido    Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId  Int     @map("pedido_id")
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  usuarioId String? @map("usuario_id")

  @@index([pedidoId])
  @@index([creadoEn])
  @@map("historial_estados_pedido")
}

model Envio {
  id            Int         @id @default(autoincrement())
  empresaEnvio  String?     @map("empresa_envio")
  numeroGuia    String?     @map("numero_guia")
  estadoEnvio   EstadoEnvio @default(preparando) @map("estado_envio")
  fechaEnvio    DateTime?   @map("fecha_envio")
  fechaEntrega  DateTime?   @map("fecha_entrega")
  notas         String?     @db.Text
  creadoEn      DateTime    @default(now()) @map("creado_en")
  actualizadoEn DateTime    @updatedAt @map("actualizado_en")

  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId Int    @map("pedido_id")

  @@index([pedidoId])
  @@index([numeroGuia])
  @@map("envios")
}

model Factura {
  id          Int       @id @default(autoincrement())
  uuidFiscal  String?   @map("uuid_fiscal")
  folio       String?
  serie       String?
  xmlUrl      String?   @map("xml_url")
  pdfUrl      String?   @map("pdf_url")
  estado      String?
  creadoEn    DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId Int    @map("pedido_id")

  @@index([pedidoId])
  @@map("facturas")
}

model Valoracion {
  id         Int      @id @default(autoincrement())
  puntuacion Int
  comentario String?  @db.Text
  creadoEn   DateTime @default(now()) @map("creado_en")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId  String   @map("usuario_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId Int      @map("producto_id")
  pedido     Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId   Int      @map("pedido_id")

  @@unique([usuarioId, productoId])
  @@index([productoId])
  @@index([pedidoId])
  @@map("valoraciones")
}

model Devolucion {
  id          Int      @id @default(autoincrement())
  motivo      String?  @db.Text
  estado      String
  monto       Decimal? @db.Decimal(10, 2)
  creadoEn    DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  pedido       Pedido      @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pedidoId     Int         @map("pedido_id")
  pedidoItem   PedidoItem? @relation(fields: [pedidoItemId], references: [id], onDelete: SetNull)
  pedidoItemId Int?        @map("pedido_item_id")
  pago         Pago?       @relation(fields: [pagoId], references: [id], onDelete: SetNull)
  pagoId       Int?        @map("pago_id")

  @@index([pedidoId])
  @@index([estado])
  @@map("devoluciones")
}

model Notificacion {
  id        String   @id @default(uuid())
  tipo      String
  titulo    String
  mensaje   String   @db.Text
  leida     Boolean  @default(false)
  metadata  Json?
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId String  @map("usuario_id")

  @@index([usuarioId])
  @@index([leida])
  @@map("notificaciones")
}

// Tabla para preguntas predefinidas disponibles (solo para mostrar opciones)
model PreguntaDisponible {
  id        String   @id @default(uuid())
  pregunta  String   @unique
  activa    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("preguntas_disponibles")
}

// Tabla para tokens JWT revocados (blacklist)
model TokenRevocado {
  id        String   @id @default(uuid())
  token     String   @unique
  expiraEn  DateTime @map("expira_en")
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([expiraEn])
  @@map("tokens_revocados")
}

// Tabla para códigos temporales de OAuth (Authorization Code Flow)
model CodigoOAuth {
  id        String   @id @default(uuid())
  codigo    String   @unique
  token     String   // Token JWT asociado
  expiraEn  DateTime @map("expira_en")
  usado     Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([codigo])
  @@index([expiraEn])
  @@map("codigos_oauth")
}

// Tabla principal de productos
model Producto {
  id               Int                     @id @default(autoincrement())
  nombre           String
  marca            String
  descripcion      String?                 @db.VarChar(1000)
  descripcionLarga String?                 @db.Text @map("descripcion_larga")
  descuento        Int?                    // Porcentaje de descuento aplicable a presentaciones
  categoria        String?
  nuevo            Boolean                 @default(false)
  crueltyFree      Boolean                 @default(false) @map("cruelty_free")
  caracteristicas  String[]                @default([])
  ingredientes     String?
  modoUso          String?                 @db.Text @map("modo_uso")
  resultado        String?                 @db.Text
  creadoEn         DateTime                @default(now()) @map("creado_en")
  actualizadoEn    DateTime                @updatedAt @map("actualizado_en")

  presentaciones      ProductoPresentacion[]
  serviciosAsociados  ServicioProducto[]
  pedidoItems         PedidoItem[]
  carritoItems        CarritoItem[]
  valoraciones        Valoracion[]

  @@index([categoria])
  @@map("productos")
}

// Tabla de presentaciones de cada producto
model ProductoPresentacion {
  id              Int       @id @default(autoincrement())
  tamanio         String
  imagenes        String[]  @default([])
  precio          Decimal   @db.Decimal(10, 2)
  precioOriginal  Decimal?  @map("precio_original") @db.Decimal(10, 2)
  stock           Int       @default(0)
  disponible      Boolean   @default(true)
  fechaCaducidad  DateTime? @map("fecha_caducidad")
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId     Int       @map("producto_id")
  pedidoItems    PedidoItem[]
  carritoItems   CarritoItem[]
  movimientosInventario InventarioMovimiento[]

  @@map("producto_presentaciones")
  @@index([productoId])
}

model InventarioMovimiento {
  id            Int                     @id @default(autoincrement())
  tipo          MovimientoInventarioTipo
  motivo        String?
  cantidad      Int
  stockAntes    Int                     @map("stock_antes")
  stockDespues  Int                     @map("stock_despues")
  referenciaTipo String?                @map("referencia_tipo")
  referenciaId   String?                @map("referencia_id")
  creadoEn      DateTime                @default(now()) @map("creado_en")

  presentacion   ProductoPresentacion   @relation(fields: [presentacionId], references: [id], onDelete: Restrict)
  presentacionId Int                    @map("presentacion_id")
  usuario        Usuario?               @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  usuarioId      String?                @map("usuario_id")

  @@index([presentacionId])
  @@index([usuarioId])
  @@index([tipo])
  @@index([creadoEn])
  @@map("inventario_movimientos")
}

// Servicios (corte, coloración, tratamientos, etc.)
model Servicio {
  id                  Int                @id @default(autoincrement())
  nombre              String
  descripcion         String?            @db.Text
  descripcionLarga    String?            @db.Text @map("descripcion_larga")
  precio              Decimal            @db.Decimal(10, 2)
  duracionMinutos     Int                 @map("duracion_minutos")
  categoria           String
  requiereEvaluacion  Boolean            @default(false) @map("requiere_evaluacion")
  imagen              Json               @default("[]")
  incluye             Json               @default("[]")
  recomendaciones     Json               @default("[]") @map("recomendaciones")
  activo              Boolean            @default(true)
  creadoEn            DateTime           @default(now()) @map("creado_en")
  actualizadoEn       DateTime           @updatedAt @map("actualizado_en")

  productosAsociados  ServicioProducto[]
  especialistas       ServicioEspecialista[]

  @@index([categoria])
  @@index([activo])
  @@map("servicios")
}

// Productos asociados a un servicio (qué productos se usan y en qué cantidad)
model ServicioProducto {
  id                Int      @id @default(autoincrement())
  cantidadEstimada  Decimal  @default(1) @map("cantidad_estimada") @db.Decimal(10, 2)

  servicio          Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  servicioId        Int      @map("servicio_id")
  producto          Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId        Int      @map("producto_id")

  @@unique([servicioId, productoId])
  @@map("servicio_productos")
  @@index([servicioId])
  @@index([productoId])
}

// Especialistas asignados a un servicio (usuarios que realizan ese servicio)
model ServicioEspecialista {
  id         Int      @id @default(autoincrement())
  servicioId Int      @map("servicio_id")
  usuarioId  String   @map("usuario_id")

  servicio   Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([servicioId, usuarioId])
  @@map("servicio_especialistas")
  @@index([servicioId])
  @@index([usuarioId])
}

// Paquetes promocionales (tabla existente en BD)
model Paquete {
  id                   Int      @id @default(autoincrement())
  tipo_evento          String
  descripcion          String   @db.Text
  servicios_vinculados String[] @default([])
  precio_especial      Decimal  @db.Decimal(10, 2)

  @@map("paquetes")
}
