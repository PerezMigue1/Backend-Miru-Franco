// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoCabello {
  liso
  ondulado
  rizado
}

model Usuario {
  id                    String         @id @default(uuid())
  nombre                String
  email                 String         @unique
  telefono              String?
  password              String?
  fechaNacimiento       DateTime?
  googleId              String?        @unique
  foto                  String?
  aceptaAvisoPrivacidad Boolean        @default(false)
  recibePromociones     Boolean        @default(false)
  resetPasswordToken    String?
  resetPasswordExpires  DateTime?
  codigoOTP             String?
  otpExpira             DateTime?
  confirmado            Boolean        @default(false)
  creadoEn              DateTime       @default(now()) @map("creado_en")
  actualizadoEn         DateTime       @updatedAt @map("actualizado_en")
  activo                Boolean        @default(true)
  
  // Campos de seguridad
  intentosLoginFallidos Int            @default(0) @map("intentos_login_fallidos")
  cuentaBloqueadaHasta  DateTime?      @map("cuenta_bloqueada_hasta")
  ultimoIntentoLogin    DateTime?      @map("ultimo_intento_login")
  ultimaActividad       DateTime?      @map("ultima_actividad") // Última actividad del usuario (para expiración por inactividad)
  tokensRevocadosDesde  DateTime?      @map("tokens_revocados_desde") // Fecha desde la cual todos los tokens anteriores están revocados (para logout global)
  rol                   String         @default("cliente") // admin | estilista | empleado | becario | cliente

  // Campos de dirección (embebidos)
  calle                 String?
  numero                String?
  colonia               String?
  ciudad                String?
  estado                String?
  codigoPostal          String?        @map("codigo_postal")

  // Campos de perfil capilar (embebidos)
  tipoCabello           TipoCabello?
  colorNatural          String?        @map("color_natural")
  colorActual           String?        @map("color_actual")
  productosUsados       String?        @map("productos_usados")
  alergias              String?

  // Campos de pregunta de seguridad (embebidos)
  preguntaSeguridad     String?        @map("pregunta_seguridad")
  respuestaSeguridad    String?        @map("respuesta_seguridad") // Hasheada con bcrypt

  serviciosComoEspecialista ServicioEspecialista[]

  @@index([activo])
  @@index([email])
  @@map("usuarios")
}

// Tabla para preguntas predefinidas disponibles (solo para mostrar opciones)
model PreguntaDisponible {
  id        String   @id @default(uuid())
  pregunta  String   @unique
  activa    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("preguntas_disponibles")
}

// Tabla para tokens JWT revocados (blacklist)
model TokenRevocado {
  id        String   @id @default(uuid())
  token     String   @unique
  expiraEn  DateTime @map("expira_en")
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([expiraEn])
  @@map("tokens_revocados")
}

// Tabla para códigos temporales de OAuth (Authorization Code Flow)
model CodigoOAuth {
  id        String   @id @default(uuid())
  codigo    String   @unique
  token     String   // Token JWT asociado
  expiraEn  DateTime @map("expira_en")
  usado     Boolean  @default(false)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([codigo])
  @@index([expiraEn])
  @@map("codigos_oauth")
}

// Tabla principal de productos
model Producto {
  id               Int                     @id @default(autoincrement())
  nombre           String
  marca            String
  descripcion      String?                 @db.VarChar(1000)
  descripcionLarga String?                 @db.Text @map("descripcion_larga")
  imagenes         String[]                @default([])
  descuento        Int?                    // Porcentaje de descuento aplicable a presentaciones
  categoria        String?
  nuevo            Boolean                 @default(false)
  crueltyFree      Boolean                 @default(false) @map("cruelty_free")
  caracteristicas  String[]                @default([])
  ingredientes     String?
  modoUso          String?                 @db.Text @map("modo_uso")
  resultado        String?                 @db.Text
  creadoEn         DateTime                @default(now()) @map("creado_en")
  actualizadoEn    DateTime                @updatedAt @map("actualizado_en")

  presentaciones      ProductoPresentacion[]
  serviciosAsociados  ServicioProducto[]

  @@index([categoria])
  @@map("productos")
}

// Tabla de presentaciones de cada producto
model ProductoPresentacion {
  id              Int       @id @default(autoincrement())
  tamanio         String
  precio          String
  precioOriginal  String?   @map("precio_original")
  stock           Int       @default(0)
  disponible      Boolean   @default(true)
  fechaCaducidad  DateTime? @map("fecha_caducidad")
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")

  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId     Int       @map("producto_id")

  @@map("producto_presentaciones")
  @@index([productoId])
}

// Servicios (corte, coloración, tratamientos, etc.)
model Servicio {
  id                  Int                @id @default(autoincrement())
  nombre              String
  descripcion         String?            @db.Text
  descripcionLarga    String?            @db.Text @map("descripcion_larga")
  precio              Decimal            @db.Decimal(10, 2)
  duracionMinutos     Int                 @map("duracion_minutos")
  categoria           String
  requiereEvaluacion  Boolean            @default(false) @map("requiere_evaluacion")
  imagen              Json               @default("[]")
  incluye             Json               @default("[]")
  recomendaciones     Json               @default("[]") @map("recomendaciones")
  activo              Boolean            @default(true)
  creadoEn            DateTime           @default(now()) @map("creado_en")
  actualizadoEn       DateTime           @updatedAt @map("actualizado_en")

  productosAsociados  ServicioProducto[]
  especialistas       ServicioEspecialista[]

  @@index([categoria])
  @@index([activo])
  @@map("servicios")
}

// Productos asociados a un servicio (qué productos se usan y en qué cantidad)
model ServicioProducto {
  id                Int      @id @default(autoincrement())
  cantidadEstimada  Decimal  @default(1) @map("cantidad_estimada") @db.Decimal(10, 2)

  servicio          Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  servicioId        Int      @map("servicio_id")
  producto          Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  productoId        Int      @map("producto_id")

  @@unique([servicioId, productoId])
  @@map("servicio_productos")
  @@index([servicioId])
  @@index([productoId])
}

// Especialistas asignados a un servicio (usuarios que realizan ese servicio)
model ServicioEspecialista {
  id         Int      @id @default(autoincrement())
  servicioId Int      @map("servicio_id")
  usuarioId  String   @map("usuario_id")

  servicio   Servicio @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([servicioId, usuarioId])
  @@map("servicio_especialistas")
  @@index([servicioId])
  @@index([usuarioId])
}
